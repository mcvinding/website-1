---
layout: null
permalink: /calendar.ics
---
BEGIN:VCALENDAR
VERSION:2.0
PRODID:-//EEG101//eeg101.eu//EN
X-WR-CALNAME:EEG101 Events
X-WR-CALDESC:Events from the EEG101 COST Action (CA24148)
CALSCALE:GREGORIAN
METHOD:PUBLISH
{% for event in site.data.events %}{% if event.id and event.id != "" %}BEGIN:VEVENT
UID:{{ event.id }}@eeg101.eu
DTSTAMP:{{ site.time | date: "%Y%m%dT%H%M00" }}Z
DTSTART;VALUE=DATE:{{ event.start_date | date: "%Y%m%d" }}
DTEND;VALUE=DATE:{{ event.end_date | date: "%Y%m%d" }}
SUMMARY:{{ event.title }}
DESCRIPTION:{{ event.summary | strip_newlines | truncate: 100 }}
LOCATION:{{ event.location }}
URL:https://www.eeg101.eu/news/
END:VEVENT
{% endif %}{% endfor %}END:VCALENDAR
